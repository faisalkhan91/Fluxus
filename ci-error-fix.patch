From a09ce2cbb0462faebb108d8f795335a94cd96ee4 Mon Sep 17 00:00:00 2001
From: Faisal Khan <mfkhan@sofi.org>
Date: Fri, 3 Apr 2026 00:52:10 -0700
Subject: [PATCH 1/2] fix: resolve CI lint errors and setup-node deprecation

Add keyboard handler, tabindex, and aria-hidden to backdrop div to
satisfy angular-eslint accessibility rules. Upgrade actions/setup-node
from v4.4.0 (Node 20) to v6.3.0 (Node 24) across all CI jobs.

Made-with: Cursor
---
 .github/workflows/ci.yml                            | 8 ++++----
 src/app/ui/bottom-sheet/bottom-sheet.component.html | 8 +++++++-
 2 files changed, 11 insertions(+), 5 deletions(-)

diff --git a/.github/workflows/ci.yml b/.github/workflows/ci.yml
index e6a7d50a..32be99b8 100644
--- a/.github/workflows/ci.yml
+++ b/.github/workflows/ci.yml
@@ -19,7 +19,7 @@ jobs:
     steps:
       - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
 
-      - uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020 # v4.4.0
+      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
         with:
           node-version: 24
           cache: npm
@@ -35,7 +35,7 @@ jobs:
     steps:
       - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
 
-      - uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020 # v4.4.0
+      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
         with:
           node-version: 24
           cache: npm
@@ -50,7 +50,7 @@ jobs:
     steps:
       - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
 
-      - uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020 # v4.4.0
+      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
         with:
           node-version: 24
           cache: npm
@@ -65,7 +65,7 @@ jobs:
     steps:
       - uses: actions/checkout@08c6903cd8c0fde910a37f88322edcfb5dd907a8 # v5.0.0
 
-      - uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020 # v4.4.0
+      - uses: actions/setup-node@53b83947a5a98c8d113130e565377fae1a50d02f # v6.3.0
         with:
           node-version: 24
           cache: npm
diff --git a/src/app/ui/bottom-sheet/bottom-sheet.component.html b/src/app/ui/bottom-sheet/bottom-sheet.component.html
index b350ccd8..71c1a1cc 100644
--- a/src/app/ui/bottom-sheet/bottom-sheet.component.html
+++ b/src/app/ui/bottom-sheet/bottom-sheet.component.html
@@ -1,5 +1,11 @@
 @if (open()) {
-  <div class="backdrop" (click)="onBackdropClick()"></div>
+  <div
+    class="backdrop"
+    (click)="onBackdropClick()"
+    (keydown.enter)="onBackdropClick()"
+    tabindex="-1"
+    aria-hidden="true"
+  ></div>
   <div
     class="sheet"
     [style.transform]="'translateY(' + dragOffset() + 'px)'"
-- 

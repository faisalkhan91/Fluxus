From 9dd4ae2cb7c6b0a4994e38e94a5aaf8fe3ba0e78 Mon Sep 17 00:00:00 2001
From: Faisal Khan <mfkhan@sofi.org>
Date: Fri, 3 Apr 2026 00:55:07 -0700
Subject: [PATCH 2/2] chore: Update Karma configuration to allow empty test
 suites

Added the option to fail on empty test suites in the Karma configuration, enhancing flexibility in test execution.
---
 karma.conf.js | 1 +
 1 file changed, 1 insertion(+)

diff --git a/karma.conf.js b/karma.conf.js
index effb15ab..75318fda 100644
--- a/karma.conf.js
+++ b/karma.conf.js
@@ -36,5 +36,6 @@ module.exports = function (config) {
     browsers: ['Chrome'],
     singleRun: false,
     restartOnFileChange: true,
+    failOnEmptyTestSuite: false,
   });
 };
-- 

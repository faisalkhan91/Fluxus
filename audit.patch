 -->
-<div class="blog-layout" animate.enter="fade-in">
+<div class="blog-layout">
   <header class="blog-header">
     <ui-section-header
       title="Blog"
@@ -57,21 +62,19 @@
         ) {
           <!--
             Stagger choreography:
-            - `--enter-delay` ramps from 0ms by 30ms per card (down from
-              50ms) so the wave is tight enough to feel like one entrance
-              instead of a queue.
-            - The featured (first) card is special-cased in CSS
-              (`.post-link--featured.enter-fade-up`) to swap the
-              translateY keyframe for an opacity-only fade. Translating
-              the heavy cover image while it's still loading reads as
-              jank — the rest of the cards are text-only and rise
-              cleanly, so the slide is reserved for them.
+            - `--enter-delay` ramps from 0ms by 30ms per card so the
+              wave reads as one entrance instead of a queue. It feeds
+              the `transition-delay` declared on `.post-link` in the
+              stylesheet.
+            - The featured (first) card is special-cased in CSS to
+              skip the translateY rise (opacity-only fade). Sliding
+              the heavy cover image while it's still decoding reads
+              as jank; the remaining text-only cards keep the rise.
           -->

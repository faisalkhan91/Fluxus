+      const onPointerMove = (event: PointerEvent) => {
+        pendingX = event.clientX / window.innerWidth;
+        pendingY = event.clientY / window.innerHeight;
+        if (raf) return;
+        raf = requestAnimationFrame(flush);
+      };

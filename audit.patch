 package.json | 4 +++-
 1 file changed, 3 insertions(+), 1 deletion(-)

diff --git a/package.json b/package.json
index 0c0b2273..a7263629 100644
--- a/package.json
+++ b/package.json
@@ -10,8 +10,10 @@
     "watch": "ng build --watch --configuration development",
     "test": "ng test",
     "test:coverage": "ng test --configuration=coverage",
-    "lint": "ng lint",
+    "lint": "ng lint && prettier --check .",
+    "lint:fix": "ng lint --fix && prettier --write .",
     "format:check": "prettier --check .",
+    "format:write": "prettier --write .",
     "typecheck": "tsc --noEmit -p tsconfig.app.json",
     "audit:prerender": "node scripts/audit-prerender.mjs",
     "optimize:images": "node scripts/optimize-blog-images.mjs",

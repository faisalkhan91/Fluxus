{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "navigationUrls": [
    "/**",
    "!/**/*.*",
    "!/**/*__*",
    "!/**/*__*/**",
    "!/healthz",
    "!/feed.xml",
    "!/sitemap.xml"
  ],
  "assetGroups": [
    {
      "name": "app-shell",
      "installMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/favicon.svg",
          "/apple-touch-icon.png",
          "/site.webmanifest",
          "/manifest.webmanifest",
          "/index.html",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "core-assets",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/assets/images/profile/**",
          "/assets/images/og-image.png",
          "/assets/blog/posts.json"
        ]
      }
    },
    {
      "name": "blog-and-images",
      "installMode": "lazy",
      "updateMode": "lazy",
      "resources": {
        "files": ["/assets/blog/posts/**", "/assets/images/blog/**", "/og/**"]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "version-stamp",
      "urls": ["/version.json"],
      "cacheConfig": {
        "maxSize": 1,
        "maxAge": "1d",
        "timeout": "1s",
        "strategy": "freshness"
      }
    },
    {
      "name": "google-fonts",
      "urls": ["https://fonts.googleapis.com/**", "https://fonts.gstatic.com/**"],
      "cacheConfig": {
        "maxSize": 30,
        "maxAge": "30d",
        "strategy": "performance"
      }
    }
  ]
}

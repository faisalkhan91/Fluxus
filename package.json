{
  "name": "fluxus",
  "version": "3.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "node scripts/sync-reading-times.mjs && node scripts/build-image-dims.mjs && node scripts/build-version-stamp.mjs && ng build --configuration production && node scripts/inject-meta.mjs && node scripts/build-sitemap.mjs && node scripts/build-feed.mjs && node scripts/build-og-cards.mjs && node scripts/build-csp.mjs",
    "sync:reading-times": "node scripts/sync-reading-times.mjs",
    "build:version-stamp": "node scripts/build-version-stamp.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --configuration=coverage",
    "lint": "ng lint && prettier --check .",
    "lint:fix": "ng lint --fix && prettier --write .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "audit:prerender": "node scripts/audit-prerender.mjs",
    "optimize:images": "node scripts/optimize-blog-images.mjs",
    "build:image-dims": "node scripts/build-image-dims.mjs",
    "analyze": "ng build --configuration production --source-map && npx --yes source-map-explorer 'dist/fluxus/browser/main-*.js' 'dist/fluxus/browser/chunk-*.js' --no-border-checks",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:visual": "VISUAL_REGRESSION=1 playwright test tests/e2e/visual.spec.ts",
    "e2e:visual:update": "VISUAL_REGRESSION=1 playwright test tests/e2e/visual.spec.ts --update-snapshots",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "private": true,
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "dependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/platform-browser": "^21.2.7",
    "@angular/platform-server": "^21.2.7",
    "@angular/router": "^21.2.7",
    "@angular/service-worker": "^21.2.9",
    "@angular/ssr": "^21.2.6",
    "express": "~5.2.0",
    "highlight.js": "^11.11.1",
    "marked": "^17.0.5",
    "mermaid": "^11.14.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.6",
    "@angular/cli": "^21.2.6",
    "@angular/compiler-cli": "^21.2.7",
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.1",
    "@types/node": "^24.12.2",
    "@types/pdfkit": "^0.17.5",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "21.3.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.1",
    "pdfkit": "^0.18.0",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "type-fest": "^5.6.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "8.59.0",
    "vitest": "^4.1.2"
  }
}

{
  "name": "fluxus",
  "version": "4.2.1",
  "license": "MIT",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "node scripts/sync-reading-times.mjs && node scripts/build-image-dims.mjs && node scripts/build-image-variants.mjs && node scripts/build-version-stamp.mjs && ng build --configuration production && node scripts/inject-meta.mjs && node scripts/build-sitemap.mjs && node scripts/build-feed.mjs && node scripts/build-og-cards.mjs && node scripts/build-csp.mjs && node scripts/audit-csp.mjs && node scripts/audit-prerender.mjs && node scripts/audit-structured-data.mjs",
    "sync:reading-times": "node scripts/sync-reading-times.mjs",
    "fetch:projects": "node scripts/fetch-projects-github.mjs",
    "build:version-stamp": "node scripts/build-version-stamp.mjs",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:coverage": "ng test --configuration=coverage",
    "lint": "ng lint && prettier --check .",
    "lint:fix": "ng lint --fix && prettier --write .",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "audit:prerender": "node scripts/audit-prerender.mjs",
    "audit:csp": "node scripts/audit-csp.mjs",
    "audit:structured-data": "node scripts/audit-structured-data.mjs",
    "optimize:images": "node scripts/optimize-blog-images.mjs",
    "build:image-dims": "node scripts/build-image-dims.mjs",
    "build:image-variants": "node scripts/build-image-variants.mjs",
    "generate:favicon": "node scripts/generate-favicon-assets.mjs",
    "generate:resume": "node scripts/generate-resume.mjs",
    "analyze": "ng build --configuration production --source-map && npx --yes source-map-explorer 'dist/fluxus/browser/main-*.js' 'dist/fluxus/browser/chunk-*.js' --no-border-checks",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:visual": "VISUAL_REGRESSION=1 playwright test tests/e2e/visual.spec.ts",
    "e2e:visual:update": "VISUAL_REGRESSION=1 playwright test tests/e2e/visual.spec.ts --update-snapshots",
    "e2e:install": "playwright install --with-deps chromium"
  },
  "private": true,
  "engines": {
    "node": ">=24.15.0 <25",
    "npm": ">=10"
  },
  "//dependencyNotes": {
    "@types/node": "Pinned to the Node 24 LTS line to match engines.node (>=24.15.0 <25). We only support the active Node LTS; @types/node 26 tracks the Current (non-LTS) release (LTS ~Oct 2026), so do not bump it ahead of the runtime we ship on."
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/service-worker": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "@fontsource/fira-code": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "express": "~5.2.0",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.5",
    "mermaid": "^11.14.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@types/express": "^5.0.1",
    "@types/node": "^24.12.2",
    "@types/pdfkit": "^0.17.5",
    "@vitest/coverage-v8": "^4.1.5",
    "angular-eslint": "^22.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "http-server": "^14.1.1",
    "jsdom": "^29.0.1",
    "octokit": "^5.0.5",
    "pdfkit": "^0.19.1",
    "png-to-ico": "^3.0.1",
    "prettier": "^3.8.1",
    "sharp": "^0.35.2",
    "type-fest": "^5.6.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.2"
  }
}
